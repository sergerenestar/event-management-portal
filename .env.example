# Copy to .env and fill in values before running docker compose locally.
# NEVER commit .env — it is in .gitignore.

# ── SQL Server ───────────────────────────────────────────────────────────────
SA_PASSWORD=Dev@1234!

# ── Microsoft Entra External ID ──────────────────────────────────────────────
ENTRA_TENANT_ID=your-entra-tenant-id
ENTRA_CLIENT_ID=your-entra-client-id

# ── Backend JWT ──────────────────────────────────────────────────────────────
# Must be 32+ characters. Use a strong random value in production.
JWT_SIGNING_KEY=dev-signing-key-min-32-chars-replace

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
